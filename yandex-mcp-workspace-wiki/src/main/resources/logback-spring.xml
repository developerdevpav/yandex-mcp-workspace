<?xml version="1.0" encoding="UTF-8"?>
<!--
  Конфигурация логирования для транспорта stdio.

  Поток stdout зарезервирован под протокол MCP, поэтому вся диагностика пишется
  ТОЛЬКО в stderr. Запись логов в stdout сломает обмен сообщениями с MCP-клиентом.
-->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
